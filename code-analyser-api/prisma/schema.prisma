generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id String @id

  email String @unique

  createdAt DateTime @default(now())

  analyses Analysis[]

  @@map("users")
}

model Analysis {
  id String @id @default(uuid())

  instruction String

  content String

  result Json

  userId String?

  user User? @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())

  @@map("analyses")
}
